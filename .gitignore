# =============================================================
# PROJECT-SPECIFIC — Unsloth Phi-3-mini Fine-Tuning
# =============================================================

# Trained LoRA adapters — large binary files, not needed in repo
# Recreate by running the training notebook
ollama_phi_chat/

# GGUF converted model — very large (2-4GB), never commit
ollama_phi_chat_gguf/

# Training checkpoints — large, auto-generated during training
phichat/

# Unsloth compiled kernel cache — auto-generated, machine-specific
unsloth_compiled_cache/

# HuggingFace model cache — stored globally, not project-specific
.cache/
*.cache

# Model weight files — never commit large model binaries
*.safetensors
*.bin
*.pt
*.pth
*.gguf
*.ggml

# Tokenizer compiled files
*.model

# GGUF quantization temp files

# Secret keys and credentials
.webui_secret_key

# Training scripts (local development)
unsloth_phi3.py
unsloth_phi3-1.py
UnsLoth_Phi3Mini_Ollama.ipynb
*.gguf.tmp
*.gguf.part

# Ollama local model storage
.ollama/

# Training logs and metrics
runs/
wandb/
lightning_logs/
tensorboard_logs/

